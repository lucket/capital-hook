# Capital.com API credentials
CAPITAL_IDENTITY="YOUR_CAPITAL_COM_IDENTITY"
CAPITAL_PASSWORD="YOUR_CAPITAL_COM_PASSWORD"
CAPITAL_API_KEY="YOUR_CAPITAL_COM_API_KEY"

# Dashboard / API authentication
# Password required to sign in to the dashboard and call the API.
APP_PASSWORD="choose-a-strong-password"
# Secret used to sign session cookies. Set a long random value to keep
# sessions valid across restarts (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`).
# If left unset, a random key is generated per process and sessions reset on restart.
APP_SECRET_KEY=""
