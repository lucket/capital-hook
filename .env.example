# Capital.com API credentials
CAPITAL_IDENTITY="YOUR_CAPITAL_COM_IDENTITY"
CAPITAL_PASSWORD="YOUR_CAPITAL_COM_PASSWORD"
CAPITAL_API_KEY="YOUR_CAPITAL_COM_API_KEY"

# Dashboard / API authentication
# Password required to sign in to the dashboard and call the API.
APP_PASSWORD="choose-a-strong-password"
# Secret used to sign session cookies. Set a long random value to keep
# sessions valid across restarts (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`).
# If left unset, a random key is generated per process and sessions reset on restart.
APP_SECRET_KEY=""

# --- Ticker mapping (optional) ---
# When a webhook omits `epic` and sends `ticker` instead, the ticker is resolved
# to a Capital.com epic via the mapping tables. These control the resolution:
#   DEFAULT_SOURCE_PROVIDER  provider a `ticker` comes from if `source` is omitted
#   EXECUTING_PROVIDER       provider that executes trades (this app = Capital.com)
DEFAULT_SOURCE_PROVIDER="TV"
EXECUTING_PROVIDER="C"
# Complete provider/ticker/mapping config as JSON, imported into the DB on
# startup (upsert). Round-trips with `GET /api/ticker-config`. Example:
# TICKER_CONFIG='{"providers":[{"id":"TV","name":"TradingView"},{"id":"C","name":"Capital.com"}],"mappings":[{"source_provider_id":"TV","source_ticker":"XAUUSD","target_provider_id":"C","target_ticker":"GOLD"}]}'
TICKER_CONFIG=""
